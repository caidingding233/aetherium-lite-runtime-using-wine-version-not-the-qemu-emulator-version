+#ifdef BOX64_HMOS
+static int box64_hmos_scandirat(int dirfd, const char* dirp, struct dirent64*** namelist,
+                                int (*filter)(const struct dirent64*),
+                                int (*compar)(const struct dirent64**, const struct dirent64**))
+{
+    const char* rel = dirp ? dirp : ".";
+    if (dirfd == AT_FDCWD || rel[0] == '/') {
+        return scandir64(rel, namelist, filter, compar);
+    }
+
+    char path[4096];
+    int written = snprintf(path, sizeof(path), "/proc/self/fd/%d/%s", dirfd, rel);
+    if (written < 0 || (size_t)written >= sizeof(path)) {
+        errno = ENAMETOOLONG;
+        return -1;
+    }
+
+    return scandir64(path, namelist, filter, compar);
+}
