+static int hmos_path_is_wineserver(const char* path)
+{
+    const char* leaf;
+    if (!path || !path[0])
+        return 0;
+    leaf = strrchr(path, '/');
+    leaf = leaf ? leaf + 1 : path;
+    return !strcmp(leaf, "wineserver");
+}
+
+static const char* hmos_path_leaf(const char* path)
+{
+    const char* leaf;
+    if (!path || !path[0])
+        return "";
+    leaf = strrchr(path, '/');
+    return leaf ? leaf + 1 : path;
+}
+
+static int hmos_path_is_wine_preloader(const char* path)
+{
+    const char* leaf = hmos_path_leaf(path);
+    return !strcmp(leaf, "wine64-preloader") || !strcmp(leaf, "wine-preloader");
+}
+
+static int hmos_path_is_wine_unix_loader(const char* path)
+{
+    const char* leaf = hmos_path_leaf(path);
+    return !strcmp(leaf, "wine64") || !strcmp(leaf, "wine");
+}
+
+static int hmos_argv_count(char* const argv[])
+{
+    int argc = 0;
+    if (!argv)
+        return 0;
+    while (argv[argc])
+        ++argc;
+    return argc;
+}
+
+static int hmos_path_is_hmos_loader(const char* path)
+{
+    const char* leaf = hmos_path_leaf(path);
+    return !strcmp(leaf, "wine-hmos-loader.so");
+}
