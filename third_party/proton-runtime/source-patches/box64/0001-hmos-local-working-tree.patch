+static int hmos_inprocess_handle_wineserver_spawn(pid_t* pid, const char* call, const char* path)
+{
+    hmos_wineserver_spawn_fn spawn_fn;
+    int bridge_pid = -1;
+    int ret;
+
+    dlerror();
+    spawn_fn = (hmos_wineserver_spawn_fn)dlsym(RTLD_DEFAULT, "wine_hmos_server_spawn_wineserver");
+    if (!spawn_fn) {
+        errno = ENOSYS;
+        printf_log(LOG_NONE, "HMOS in-process mode cannot spawn Wine server on %s; native bridge symbol is missing\n",
+            path ? path : "<none>");
+        OH_LOG_ERROR(LOG_APP, "HMOS in-process wineserver bridge symbol missing for %{public}s via %{public}s",
+            path ? path : "<none>", call ? call : "spawn");
+        if (pid)
+            *pid = -1;
+        return ENOSYS;
+    }
+
+    ret = spawn_fn(path, &bridge_pid);
+    if (!ret) {
+        if (pid)
+            *pid = (pid_t)bridge_pid;
+        if (bridge_pid > 0)
+            hmos_wineserver_fake_pid = (pid_t)bridge_pid;
+        printf_log(LOG_INFO, "HMOS in-process Wine server bridge handled %s pid=%d\n",
+            path ? path : "<none>", bridge_pid);
+        OH_LOG_INFO(LOG_APP, "HMOS in-process wineserver bridge handled %{public}s pid=%{public}d",
+            path ? path : "<none>", bridge_pid);
+        return 0;
+    }
+
+    errno = ret;
+    if (pid)
+        *pid = -1;
+    printf_log(LOG_NONE, "HMOS in-process mode cannot spawn Wine server on %s; native bridge returned %d\n",
+        path ? path : "<none>", ret);
+    OH_LOG_ERROR(LOG_APP, "HMOS in-process wineserver bridge failed for %{public}s via %{public}s code=%{public}d",
+        path ? path : "<none>", call ? call : "spawn", ret);
+    return ret;
+}
