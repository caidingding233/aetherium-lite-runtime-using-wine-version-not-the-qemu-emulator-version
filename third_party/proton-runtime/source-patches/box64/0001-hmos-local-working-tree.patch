+static int hmos_inprocess_strict_process_model(void)
+{
+    const char* strict = getenv("WINE_HMOS_INPROCESS_STRICT");
+    if (!strict || !strict[0])
+        return 1;
+    return strcmp(strict, "0") && strcasecmp(strict, "false") && strcasecmp(strict, "no");
+}
+
+static uintptr_t hmos_inprocess_guest_return(uintptr_t guest_rsp)
+{
+    if (!guest_rsp || !(getProtection(guest_rsp) & PROT_READ))
+        return 0;
+    return *(uintptr_t*)guest_rsp;
+}
