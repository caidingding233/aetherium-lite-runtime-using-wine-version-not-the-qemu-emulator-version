+static const char* hmos_inprocess_rewrite_wine_tmp_path(const char* path, char* rewritten, size_t rewritten_size)
+{
+    static const char tmp_prefix[] = "/tmp/.wine-";
+    const char* wineprefix;
+    const char* suffix;
+    int written;
+
+    if (!hmos_inprocess_is_active() || !path || strncmp(path, tmp_prefix, sizeof(tmp_prefix) - 1))
+        return path;
+
+    wineprefix = getenv("WINEPREFIX");
+    if (!wineprefix || !wineprefix[0])
+        return path;
+
+    suffix = strchr(path + sizeof(tmp_prefix) - 1, '/');
+    if (!suffix)
+        suffix = "";
+
+    written = snprintf(rewritten, rewritten_size, "%s/.wineserver%s", wineprefix, suffix);
+    if (written <= 0 || (size_t)written >= rewritten_size)
+        return path;
+
+    printf_log(LOG_INFO, "HMOS in-process rewrote Wine server dir path %s -> %s\n", path, rewritten);
+    OH_LOG_INFO(LOG_APP, "HMOS in-process rewrote Wine server dir path %{public}s -> %{public}s",
+        path, rewritten);
+    return rewritten;
+}
