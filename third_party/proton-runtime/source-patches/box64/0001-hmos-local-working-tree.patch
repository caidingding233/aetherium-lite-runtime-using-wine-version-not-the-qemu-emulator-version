+static int hmos_inprocess_handle_spawn_call(pid_t* pid, const char* call, const char* path, char* const argv[],
+                                            int* handled, uintptr_t caller, uintptr_t guest_rsp)
+{
+    const char* caller_name;
+    uintptr_t ret_addr;
+    const char* ret_name;
+    if (handled)
+        *handled = 0;
+    if (!hmos_inprocess_is_active())
+        return 0;
+    if (handled)
+        *handled = 1;
+    if (hmos_path_is_wineserver(path))
+        return hmos_inprocess_handle_wineserver_spawn(pid, call, path);
+    if (pid)
+        *pid = -1;
+    errno = ENOSYS;
+    caller_name = caller ? getAddrFunctionName(caller) : "<unknown>";
+    ret_addr = hmos_inprocess_guest_return(guest_rsp);
+    ret_name = ret_addr ? getAddrFunctionName(ret_addr) : "<unknown>";
+    hmos_inprocess_write_process_broker_request(call, path, argv, caller, guest_rsp);
+    printf_log(LOG_NONE, "HMOS in-process mode blocked guest %s on %s at %p/%s ret %p/%s; host process launch is not available\n",
+        call ? call : "spawn", path ? path : "<none>", (void*)caller, caller_name, (void*)ret_addr, ret_name);
+    OH_LOG_WARN(LOG_APP, "HMOS in-process blocked guest %{public}s on %{public}s at 0x%{public}llx/%{public}s ret 0x%{public}llx/%{public}s",
+        call ? call : "spawn", path ? path : "<none>", (unsigned long long)caller, caller_name,
+        (unsigned long long)ret_addr, ret_name);
+    return ENOSYS;
+}
