+static int hmos_inprocess_try_soft_exec_wine_loader(const char* call, const char* path,
+                                                    char* const argv[], char* const envp[])
+{
+    int argc;
+    int rc;
+    int soft_argc;
+    char** soft_env;
+    const char* hmos_loader;
+    const char** soft_argv = NULL;
+    if (!hmos_inprocess_is_active() || hmos_inprocess_strict_process_model())
+        return 0;
+    if (hmos_path_is_wine_preloader(path)) {
+        errno = ENOENT;
+        OH_LOG_INFO(LOG_APP, "HMOS in-process soft-exec skipping %{public}s preloader %{public}s",
+            call ? call : "exec", path ? path : "<none>");
+        return 1;
+    }
+    if (!hmos_path_is_wine_unix_loader(path))
+        return 0;
+    argc = hmos_argv_count(argv);
+    if (argc <= 0)
+        return 0;
+    if (hmos_inprocess_write_process_broker_request(call, path, argv, 0, 0)) {
+        OH_LOG_INFO(LOG_APP, "HMOS in-process soft-exec handed %{public}s to Wine broker path=%{public}s target=%{public}s",
+            call ? call : "exec", path ? path : "<none>", (argc > 1 && argv[1]) ? argv[1] : "<none>");
+        syscall(SYS_exit_group, 0);
+        __builtin_unreachable();
+    }
+    soft_env = envp ? (char**)envp : environ;
+    hmos_loader = getenv("WINELOADER");
+    if (hmos_loader && hmos_loader[0] && hmos_path_is_hmos_loader(hmos_loader) &&
+        &box64_hmos_call_symbol && box64_hmos_call_symbol) {
+        soft_argc = argc + 1;
+        soft_argv = calloc(soft_argc + 1, sizeof(*soft_argv));
+        if (soft_argv) {
+            soft_argv[0] = "box64-hmos-soft-exec";
+            soft_argv[1] = hmos_loader;
+            for (int i = 1; i < argc; ++i)
+                soft_argv[i + 1] = argv[i];
+            soft_argv[soft_argc] = NULL;
+            OH_LOG_INFO(LOG_APP,
+                "HMOS in-process soft-exec %{public}s via wine_hmos_main loader=%{public}s argc=%{public}d target=%{public}s socket=%{public}s",
+                call ? call : "exec", hmos_loader, soft_argc,
+                (soft_argc > 2 && soft_argv[2]) ? soft_argv[2] : "<none>",
+                getenv("WINESERVERSOCKET") ? getenv("WINESERVERSOCKET") : "<unset>");
+            rc = box64_hmos_call_symbol(soft_argc, soft_argv, soft_env, "wine_hmos_main");
+            OH_LOG_INFO(LOG_APP, "HMOS in-process soft-exec wine_hmos_main returned rc=%{public}d; exiting process", rc);
+            free(soft_argv);
+            syscall(SYS_exit_group, rc < 0 ? 1 : rc);
+            __builtin_unreachable();
+        }
+        OH_LOG_WARN(LOG_APP, "HMOS in-process soft-exec argv allocation failed; falling back to ELF loader");
+    }
+    if (!(&box64_hmos_main) || !box64_hmos_main)
+        return 0;
+    OH_LOG_INFO(LOG_APP, "HMOS in-process soft-exec %{public}s via ELF path=%{public}s argc=%{public}d argv1=%{public}s socket=%{public}s",
+        call ? call : "exec", path ? path : "<none>", argc,
+        (argc > 1 && argv[1]) ? argv[1] : "<none>", getenv("WINESERVERSOCKET") ? getenv("WINESERVERSOCKET") : "<unset>");
+    rc = box64_hmos_main(argc, (const char**)argv, soft_env);
+    OH_LOG_INFO(LOG_APP, "HMOS in-process soft-exec ELF returned rc=%{public}d; exiting process", rc);
+    syscall(SYS_exit_group, rc < 0 ? 1 : rc);
+    __builtin_unreachable();
+}
