+static const char* hmos_inprocess_virtual_dosdevice_target(const char* path)
+{
+    const char* wineprefix;
+    char dosdevices[MAX_PATH];
+    size_t len;
+    const char* name;
+    int written;
+
+    if (!hmos_inprocess_is_active() || !path)
+        return NULL;
+
+    wineprefix = getenv("WINEPREFIX");
+    if (!wineprefix || !wineprefix[0])
+        return NULL;
+
+    written = snprintf(dosdevices, sizeof(dosdevices), "%s/dosdevices/", wineprefix);
+    if (written <= 0 || (size_t)written >= sizeof(dosdevices))
+        return NULL;
+
+    len = strlen(dosdevices);
+    if (strncmp(path, dosdevices, len))
+        return NULL;
+
+    name = path + len;
+    if (strchr(name, '/'))
+        return NULL;
+    if (!strcmp(name, "c:"))
+        return "../drive_c";
+    if (!strcmp(name, "z:"))
+        return "/";
+    return NULL;
+}
+
+#define HMOS_PATCH_DOSDEVICE_LSTAT(path, stptr)                                      \
+    do {                                                                            \
+        const char* hmos_dos_target__ = hmos_inprocess_virtual_dosdevice_target(path); \
+        if (hmos_dos_target__) {                                                    \
+            (stptr)->st_mode = ((stptr)->st_mode & ~S_IFMT) | S_IFLNK | 0777;       \
+            (stptr)->st_size = strlen(hmos_dos_target__);                           \
+            if (!(stptr)->st_nlink)                                                 \
+                (stptr)->st_nlink = 1;                                              \
+        }                                                                           \
+    } while (0)
+
+static ssize_t hmos_inprocess_virtual_dosdevice_readlink(const char* path, char* buf, size_t sz)
+{
+    const char* target = hmos_inprocess_virtual_dosdevice_target(path);
+    size_t len;
+
+    if (!target)
+        return -1;
+    len = strlen(target);
+    if (sz > 0)
+        memcpy(buf, target, len < sz ? len : sz);
+    return len < sz ? (ssize_t)len : (ssize_t)sz;
+}
