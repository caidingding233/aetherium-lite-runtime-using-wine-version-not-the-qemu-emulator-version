+extern int box64_hmos_call_symbol(int argc, const char **argv, char **env, const char *symbol) __attribute__((weak));
+static int hmos_inprocess_is_active(void)
+{
+    return &box64_hmos_inprocess_mode && box64_hmos_inprocess_mode;
+}
