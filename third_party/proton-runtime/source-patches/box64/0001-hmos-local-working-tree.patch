+#ifdef BOX64_HMOS_INPROCESS
+static int hmos_guest_host_prot(int prot)
+{
+    int host_prot = prot & ~PROT_EXEC;
+    if ((prot & PROT_EXEC) && !(host_prot & PROT_READ))
+        host_prot |= PROT_READ;
+    return host_prot;
+}
+
+static void* hmos_fixed_private_file_mmap(void *addr, size_t length, int prot, int flags, int fd, ssize_t offset, int first_errno)
+{
+    if (!addr || fd < 0 || (flags & MAP_ANONYMOUS) || !(flags & MAP_FIXED) || !(flags & MAP_PRIVATE) ||
+        (flags & MAP_FIXED_NOREPLACE))
+        return MAP_FAILED;
+    if (!have48bits && ((uintptr_t)addr > 0x7fffffffffULL || length > (0x7fffffffffULL - (uintptr_t)addr)))
+        return MAP_FAILED;
+
+    const int host_prot = hmos_guest_host_prot(prot);
+    const int map_prot = hmos_guest_host_prot(prot | PROT_READ | PROT_WRITE);
+    const int anon_flags = (flags | MAP_ANONYMOUS | MAP_PRIVATE) & ~MAP_FIXED_NOREPLACE;
+    InternalMunmap(addr, length);
+    void *ret = InternalMmap(addr, length, map_prot, anon_flags, -1, 0);
+    if (ret == MAP_FAILED)
+        return MAP_FAILED;
+
+    size_t done = 0;
+    while (done < length) {
+        ssize_t got = pread(fd, (char*)ret + done, length - done, offset + done);
+        if (got > 0) {
+            done += got;
+            continue;
+        }
+        if (got == 0) break;
+        if (errno == EINTR) continue;
+        int read_errno = errno;
+        InternalMunmap(ret, length);
+        errno = read_errno;
+        return MAP_FAILED;
+    }
+
+    if (mprotect(ret, length, host_prot) != 0) {
+        int protect_errno = errno;
+        InternalMunmap(ret, length);
+        errno = protect_errno;
+        return MAP_FAILED;
+    }
+    setProtection_mmap((uintptr_t)ret, length, prot);
+
+    printf_log(LOG_INFO, "HMOS MAP_FIXED private file fallback mapped addr=%p len=0x%zx prot=0x%x flags=0x%x first_errno=%d copied=0x%zx\n",
+        addr, length, prot, flags, first_errno, done);
+    return ret;
+}
