+static const char* hmos_inprocess_resolve_at_path(int fd, const char* path, char* resolved, size_t resolved_size)
+{
+    char fd_path[64];
+    char dir_path[MAX_PATH];
+    ssize_t len;
+    int written;
+
+    if (!path || path[0] == '/' || fd == AT_FDCWD)
+        return path;
+
+    written = snprintf(fd_path, sizeof(fd_path), "/proc/self/fd/%d", fd);
+    if (written <= 0 || (size_t)written >= sizeof(fd_path))
+        return path;
+
+    len = readlink(fd_path, dir_path, sizeof(dir_path) - 1);
+    if (len <= 0)
+        return path;
+    dir_path[len] = '\0';
+
+    written = snprintf(resolved, resolved_size, "%s/%s", dir_path, path);
+    if (written <= 0 || (size_t)written >= resolved_size)
+        return path;
+    return resolved;
+}
