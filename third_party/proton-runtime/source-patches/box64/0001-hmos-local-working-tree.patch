+static unsigned long hmos_process_broker_seq = 0;
+
+static void hmos_inprocess_write_argv_fields(FILE* request, char* const argv[])
+{
+    int argc = 0;
+    if (!request || !argv)
+        return;
+    while (argv[argc])
+        ++argc;
+    fprintf(request, "argc=%d\n", argc);
+    for (int i = 0; i < argc && i < 64; ++i)
+        fprintf(request, "argv.%d=%s\n", i, argv[i] ? argv[i] : "");
+}
+
+static void hmos_inprocess_write_command_field(FILE* request, char* const argv[])
+{
+    size_t used = 0;
+    char command[4096];
+    if (!request || !argv || !argv[0])
+        return;
+    command[0] = '\0';
+    for (int i = 0; argv[i] && i < 64; ++i) {
+        const char* arg = argv[i];
+        int needs_quote = 0;
+        for (const char* p = arg; *p; ++p) {
+            if (*p == ' ' || *p == '\t' || *p == '"') {
+                needs_quote = 1;
+                break;
+            }
+        }
+        if (used + strlen(arg) + 4 >= sizeof(command))
+            break;
+        if (i)
+            command[used++] = ' ';
+        if (needs_quote)
+            command[used++] = '"';
+        for (const char* p = arg; *p && used + 2 < sizeof(command); ++p) {
+            if (*p == '"')
+                command[used++] = '\\';
+            command[used++] = *p;
+        }
+        if (needs_quote)
+            command[used++] = '"';
+        command[used] = '\0';
+    }
+    fprintf(request, "cmd=%s\n", command);
+}
+
+static void hmos_inprocess_write_exec_env_field(FILE* request, const char* name)
+{
+    const char* value;
+    if (!request || !name || !name[0])
+        return;
+    value = getenv(name);
+    if (value && value[0])
+        fprintf(request, "exec_env.%s=%s\n", name, value);
+}
+
+static int hmos_inprocess_write_process_broker_request(const char* call, const char* path,
+                                                       char* const argv[], uintptr_t caller, uintptr_t guest_rsp)
+{
+    const char* broker_dir = getenv("WINE_HMOS_PROCESS_BROKER_DIR");
+    const char* backend = getenv("WINE_HMOS_EXEC_BACKEND");
+    const char* isolation = getenv("WINE_HMOS_PROCESS_ISOLATION");
+    const char* slot = getenv("WINE_HMOS_PROCESS_SLOT_ID");
+    const char* caller_name = caller ? getAddrFunctionName(caller) : "<unknown>";
+    uintptr_t ret_addr = hmos_inprocess_guest_return(guest_rsp);
+    const char* ret_name = ret_addr ? getAddrFunctionName(ret_addr) : "<unknown>";
+    char request_path[MAX_PATH];
+    char cwd[MAX_PATH];
+    FILE* request;
+    int written;
+
+    if (!broker_dir || !broker_dir[0])
+        return 0;
+
+    written = snprintf(request_path, sizeof(request_path), "%s/box64-request-%ld-%lu.txt",
+                       broker_dir, (long)getpid(), ++hmos_process_broker_seq);
+    if (written <= 0 || (size_t)written >= sizeof(request_path))
+        return 0;
+
+    request = fopen(request_path, "w");
+    if (!request) {
+        OH_LOG_WARN(LOG_APP, "HMOS process broker request write failed dir=%{public}s errno=%{public}d",
+            broker_dir, errno);
+        return 0;
+    }
+
+    fprintf(request, "version=1\n");
+    fprintf(request, "source=box64-libc-wrapper\n");
+    fprintf(request, "backend=%s\n", backend ? backend : "");
+    fprintf(request, "isolation=%s\n", isolation ? isolation : "");
+    fprintf(request, "slot=%s\n", slot ? slot : "");
+    fprintf(request, "pid=%ld\n", (long)getpid());
+    if (getcwd(cwd, sizeof(cwd)))
+        fprintf(request, "cwd=%s\n", cwd);
+    fprintf(request, "call=%s\n", call ? call : "process call");
+    fprintf(request, "path=%s\n", path ? path : "");
+    hmos_inprocess_write_command_field(request, argv);
+    hmos_inprocess_write_argv_fields(request, argv);
+    hmos_inprocess_write_exec_env_field(request, "WINESERVERSOCKET");
+    hmos_inprocess_write_exec_env_field(request, "WINEPRELOADRESERVE");
+    hmos_inprocess_write_exec_env_field(request, "WINELOADERNOEXEC");
+    hmos_inprocess_write_exec_env_field(request, "WINE_LD_PRELOAD");
+    hmos_inprocess_write_exec_env_field(request, "LD_PRELOAD");
+    hmos_inprocess_write_exec_env_field(request, "BOX64_ARG0");
+    fprintf(request, "caller=0x%llx\n", (unsigned long long)caller);
+    fprintf(request, "caller_name=%s\n", caller_name ? caller_name : "");
+    fprintf(request, "return=0x%llx\n", (unsigned long long)ret_addr);
+    fprintf(request, "return_name=%s\n", ret_name ? ret_name : "");
+    fprintf(request, "status=blocked\n");
+    fprintf(request, "reason=box64 in-process process call requires Wine broker\n");
+    fclose(request);
+
+    OH_LOG_WARN(LOG_APP, "HMOS process broker request queued path=%{public}s call=%{public}s target=%{public}s ret=%{public}s",
+        request_path, call ? call : "process call", path ? path : "<none>", ret_name ? ret_name : "<unknown>");
+    return 1;
+}
+
+static int hmos_inprocess_process_call_is_fork(const char* call)
+{
+    return call && (!strcmp(call, "fork") || !strcmp(call, "vfork"));
+}
+
+static int hmos_inprocess_forbid_process_call(const char* call, const char* path, char* const argv[],
+                                              uintptr_t caller, uintptr_t guest_rsp)
+{
+    const char* caller_name;
+    uintptr_t ret_addr;
+    const char* ret_name;
+    if (!hmos_inprocess_is_active())
+        return 0;
+    if (hmos_inprocess_process_call_is_fork(call) && !hmos_inprocess_strict_process_model()) {
+        OH_LOG_INFO(LOG_APP, "HMOS in-process allowing guest %{public}s until exec broker intercept", call);
+        return 0;
+    }
+    caller_name = caller ? getAddrFunctionName(caller) : "<unknown>";
+    ret_addr = hmos_inprocess_guest_return(guest_rsp);
+    ret_name = ret_addr ? getAddrFunctionName(ret_addr) : "<unknown>";
+    hmos_inprocess_write_process_broker_request(call, path, argv, caller, guest_rsp);
+    errno = ENOSYS;
+    printf_log(LOG_NONE, "HMOS in-process mode blocked guest %s on %s at %p/%s ret %p/%s; host process launch is not available\n",
+        call ? call : "process call", path ? path : "<none>", (void*)caller, caller_name, (void*)ret_addr, ret_name);
+    OH_LOG_WARN(LOG_APP, "HMOS in-process blocked guest %{public}s on %{public}s at 0x%{public}llx/%{public}s ret 0x%{public}llx/%{public}s",
+        call ? call : "process call", path ? path : "<none>", (unsigned long long)caller, caller_name,
+        (unsigned long long)ret_addr, ret_name);
+    return 1;
+}
