+/***********************************************************************
+ *           hmos_spawn_process
+ */
+static NTSTATUS hmos_spawn_process( const RTL_USER_PROCESS_PARAMETERS *params, int socketfd,
+                                    int unixdir, char *winedebug, const struct pe_image_info *pe_info )
+{
+    const char *broker_dir = getenv( "WINE_HMOS_PROCESS_BROKER_DIR" );
+    const char *backend = getenv( "WINE_HMOS_EXEC_BACKEND" );
+    char path[1024];
+    FILE *file;
+
+    if (!broker_dir || !broker_dir[0]) return STATUS_NOT_IMPLEMENTED;
+
+    snprintf( path, sizeof(path), "%s/request-%lu-%ld.txt", broker_dir,
+              (unsigned long)time(NULL), (long)getpid() );
+    if ((file = fopen( path, "w" )))
+    {
+        fprintf( file, "version=1\n" );
+        fprintf( file, "backend=%s\n", backend ? backend : "" );
+        fprintf( file, "pid=%ld\n", (long)getpid() );
+        fprintf( file, "socketfd=%d\n", socketfd );
+        fprintf( file, "unixdir=%d\n", unixdir );
+        fprintf( file, "winedebug=%s\n", winedebug ? winedebug : "" );
+        fprintf( file, "cmd=%s\n", debugstr_us( &params->CommandLine ) );
+        fprintf( file, "image=%s\n", debugstr_us( &params->ImagePathName ) );
+        fprintf( file, "machine=%04x\n", pe_info ? pe_info->machine : 0 );
+        fclose( file );
+        WARN( "HMOS process broker request queued backend=%s path=%s cmd=%s\n",
+              backend ? backend : "", debugstr_a(path), debugstr_us( &params->CommandLine ) );
+    }
+    else WARN( "HMOS process broker request write failed dir=%s errno=%d\n",
+               debugstr_a(broker_dir), errno );
+
+    if (getenv( "WINE_HMOS_REQUIRE_PROCESS_BROKER" ))
+        return STATUS_NO_MEMORY;
+
+    WARN( "HMOS process broker runtime bridge is not attached yet; falling back to Unix spawn path\n" );
+    return STATUS_NOT_IMPLEMENTED;
+}
+
+
 /***********************************************************************
  *           spawn_process
  */
@@ -408,6 +449,13 @@ static NTSTATUS spawn_process( const RTL_USER_PROCESS_PARAMETERS *params, int so
     pid_t pid;
     char **argv;
 
+    if (getenv( "WINE_HMOS_PROCESS_BROKER_DIR" ))
+    {
+        status = hmos_spawn_process( params, socketfd, unixdir, winedebug, pe_info );
+        if (status != STATUS_NOT_IMPLEMENTED) return status;
+        status = STATUS_SUCCESS;
+    }
+
     if (wine_server_handle_to_fd( params->hStdInput, FILE_READ_DATA, &stdin_fd, NULL ) &&
         isatty(0) && is_unix_console_handle( params->hStdInput ))
         stdin_fd = 0;
